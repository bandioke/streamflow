# Server Configuration
PORT=7575
NODE_ENV=development

# Session Security (REQUIRED - Generate with: node generate-secret.js)
SESSION_SECRET=your_random_secret_here_minimum_32_characters_long

# Database Configuration
DATABASE_PATH=./db/streamflow.db

# Upload Configuration
MAX_UPLOAD_SIZE=10gb
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv,flv,wmv,webm

# HTTPS/SSL Configuration (Production)
ENABLE_HTTPS=false
SSL_CERT_PATH=
SSL_KEY_PATH=
FORCE_HTTPS=false

# Security Configuration
ALLOWED_ORIGINS=http://localhost:7575
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Analytics Configuration
ENABLE_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# Network Monitoring
ENABLE_NETWORK_MONITORING=true
NETWORK_CHECK_INTERVAL_MS=5000
BANDWIDTH_WARNING_THRESHOLD_MBPS=50
BANDWIDTH_CRITICAL_THRESHOLD_MBPS=80

# Adaptive Bitrate
ENABLE_ADAPTIVE_BITRATE=true
AUTO_ADJUST_QUALITY=true
MIN_BITRATE_KBPS=500
MAX_BITRATE_KBPS=8000

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Cloud Storage (Optional)
ENABLE_CLOUD_BACKUP=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/streamflow.log
ENABLE_ERROR_TRACKING=false

# Performance
ENABLE_REDIS_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Feature Flags
ENABLE_WEBHOOKS=false
ENABLE_API_ACCESS=false
ENABLE_RECORDING=false
